{
  "$schema": "https://openapi.vercel.sh/vercel.json",

  "buildCommand": "npm run build",
  "outputDirectory": "dist/perfect-smile/browser",

  "redirects": [
    {
      "source": "/:path*",
      "has": [
        { "type": "host", "value": "www.theperfectsmileclinic.com" }
      ],
      "destination": "https://theperfectsmileclinic.com/:path*",
      "permanent": true
    }
  ],

  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
